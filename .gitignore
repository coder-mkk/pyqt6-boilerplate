.installed.cfg
*.egg
MANIFEST

# ==========================================
# 📦 Virtual Environments
# ==========================================
.venv/
venv/
ENV/
env/
# Poetry/Pipenv hidden folders
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==========================================
# 🖼️ Qt & UI Specifics (The "Face")
# ==========================================
# We keep .ui files, but ignore the autogenerated .py files from them
# if you prefer to compile them at runtime or via a build script.
# presentation/ui/*.py 

# Qt Creator specific project files
*.pro.user
*.autosave

# ==========================================
# 🔐 Environment & Secrets (Crucial)
# ==========================================
.env
.env.local
.env.*.local
*.secret
secrets.json

# ==========================================
# 🗄️ Databases (The "Infrastructure")
# ==========================================
# Since you store your DB in the home folder, this is a safety net
# for any local testing databases that appear in the project root.
*.db
*.sqlite3
*.sqlite3-journal

# ==========================================
# 📄 Logging & Temp Files
# ==========================================
*.log
logs/
tmp/
temp/
*.bak
*.tmp

# ==========================================
# 🖥️ OS / IDE Specifics
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs (VS Code / PyCharm)
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# 📜 Templates & Reports (Generated)
# ==========================================
# If your app generates PDFs or HTML reports, ignore the output folder
output/
reports/generated/